# API / Frontend ports
API_PORT=8080
FRONTEND_PORT=3000

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_USER=matcha
POSTGRES_PASSWORD=matcha_secret
POSTGRES_DB=matcha

# Redis
REDIS_PORT=6380

# Elasticsearch
ELASTICSEARCH_PORT=9200
ES_JAVA_OPTS=-Xms256m -Xmx256m

# MailHog (dev)
MAILHOG_UI_PORT=8025
MAILHOG_SMTP_PORT=1025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@matcha.local
SMTP_COOLDOWN_SECONDS=30

# MinIO
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=matcha-photos
MINIO_PUBLIC_BASE_URL=/storage
MINIO_PUBLIC_URL=/storage

# App URLs
VITE_API_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
PUBLIC_API_BASE_URL=http://localhost:8080

# API connection URLs
DATABASE_URL=postgres://matcha:matcha_secret@postgres:5432/matcha?sslmode=disable
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200

# Seeding
SEED_USERS_ENABLED=true
MIN_USERS_COUNT=500

# Security
JWT_SECRET=change_me_in_production
